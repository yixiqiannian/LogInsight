# ====== 服务配置 ======
HOST=0.0.0.0
PORT=8000

# ====== 数据库配置 ======
DATABASE_URL=sqlite:///./loginsight.db

# ====== LLM 模型配置 ======
# OpenAI 兼容接口配置（支持 DeepSeek、通义千问、本地模型等）
LLM_API_TYPE=openai_compatible
LLM_API_BASE=https://api.openai.com/v1
LLM_API_KEY=your-api-key-here
LLM_MODEL_NAME=gpt-3.5-turbo

# 示例：DeepSeek
# LLM_API_BASE=https://api.deepseek.com/v1
# LLM_API_KEY=sk-xxxx
# LLM_MODEL_NAME=deepseek-chat

# 示例：本地Ollama
# LLM_API_BASE=http://localhost:11434/v1
# LLM_API_KEY=ollama
# LLM_MODEL_NAME=qwen2.5:7b

# ====== 日志保留策略 ======
LOG_RETENTION_DAYS_INFO=7
LOG_RETENTION_DAYS_WARN=30
LOG_RETENTION_DAYS_ERROR=90
DEBUG_LOG_PERSIST=false

# ====== AI 分析配置 ======
CONTEXT_WINDOW_MINUTES=5
AUTO_ANALYZE_ERROR=true
MAX_ANALYSIS_QUEUE_SIZE=100

# ====== 飞书 Webhook（可选） ======
FEISHU_WEBHOOK_URL=
